---
import BaseLayout from '../layouts/BaseLayout.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import ToolCard from '../components/ui/ToolCard.astro'
import SEOHead from '../components/seo/SEOHead.astro'
import JsonLd from '../components/seo/JsonLd.astro'
import { toolRegistry } from '@devkits/core'

const BATCH_1_SLUGS = ['json-formatter', 'base64', 'url-encoder', 'uuid-generator', 'hash-generator']
const tools = toolRegistry.filter(t => BATCH_1_SLUGS.includes(t.slug))

const trustSignals = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Client-side only',
    desc: 'All processing happens in your browser. Nothing is sent to any server.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`,
    title: 'No tracking',
    desc: 'Zero analytics, zero cookies, zero surveillance. Your data is yours.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
    title: 'Open source',
    desc: 'Fully transparent. Inspect the code, fork it, contribute to it.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    title: 'Free forever',
    desc: 'No freemium, no paywalls. Every tool is free and always will be.',
  },
]
---

<BaseLayout title="DevKits — Free Developer Tools">
  <Fragment slot="head">
    <SEOHead title="DevKits — Free Developer Tools" />
    <JsonLd />
  </Fragment>

  <div class="flex flex-col min-h-screen">
    <Header />

    <main class="flex-1">
      <!-- Hero -->
      <section class="py-20 px-4 sm:px-6 lg:px-8 text-center bg-gradient-to-b from-white to-gray-50 dark:from-gray-900 dark:to-gray-900">
        <div class="max-w-3xl mx-auto">
          <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 text-sm font-medium text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 rounded-full border border-blue-200 dark:border-blue-800">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            All tools run entirely in your browser
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 dark:text-gray-100 tracking-tight">
            Fast. Private.
            <span class="text-blue-600">No BS.</span>
          </h1>
          <p class="mt-6 text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed">
            Free developer tools that run entirely in your browser. No accounts, no uploads, no tracking — just tools that work.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
            <a
              href="#tools"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors text-sm"
            >
              Browse tools
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 5v14M5 12l7 7 7-7"/>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Tools grid -->
      <section id="tools" class="py-16 px-4 sm:px-6 lg:px-8">
        <div class="max-w-screen-lg mx-auto">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-8 text-center">
            Available Tools
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {tools.map(meta => (
              <ToolCard meta={meta} />
            ))}
          </div>
        </div>
      </section>

      <!-- Trust signals -->
      <section class="py-16 px-4 sm:px-6 lg:px-8 bg-gray-50 dark:bg-gray-800/50">
        <div class="max-w-screen-lg mx-auto">
          <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 mb-10 text-center">
            Why DevKits?
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            {trustSignals.map(signal => (
              <div class="text-center">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-blue-50 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400 mb-4">
                  <Fragment set:html={signal.icon} />
                </div>
                <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2">{signal.title}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{signal.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>
