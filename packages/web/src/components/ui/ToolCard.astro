---
import type { ToolMeta } from '@devkits/core'

interface Props {
  meta: ToolMeta
}

const { meta } = Astro.props

const categoryColors: Record<string, string> = {
  formatters: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
  encoders: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400',
  generators: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
}
---

<a
  href={`/tools/${meta.slug}`}
  class="group block p-6 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm hover:shadow-md hover:border-blue-300 dark:hover:border-blue-600 transition-all"
>
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">
        {meta.name}
      </h3>
      <p class="mt-1.5 text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
        {meta.description}
      </p>
    </div>
    <span class={`shrink-0 px-2 py-0.5 text-xs font-medium rounded-full ${categoryColors[meta.category] ?? 'bg-gray-100 text-gray-600'}`}>
      {meta.category}
    </span>
  </div>
  <div class="mt-4 flex items-center text-sm text-blue-600 dark:text-blue-400 font-medium">
    Open tool
    <svg class="ml-1 w-4 h-4 group-hover:translate-x-0.5 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 12h14M12 5l7 7-7 7"/>
    </svg>
  </div>
</a>
